# Mise has many tools that are aliased by default. These are listed in the registry: https://mise.jdx.dev/registry.html
# Mise supports several backends to install tools. If a tool is not in Mise's registry, the backend must be specified.
#   - Aqua is preferred but it has its own registry so not all tools are supported:
#       https://github.com/aquaproj/aqua-registry/blob/main/registry.yaml
#   - GitHub backend can be used if tool binaries are released on GitHub.
#   - More specific backends can handle tools that do not release binary files.

[tools]
cargo-binstall = "latest"  # Used by other tools that use the `cargo` backend
neovim = "latest"

eza = "latest"
zoxide = "latest"
starship = "latest"
ripgrep = "latest"
fd = "latest"
"cargo:macchina" = "latest"
github-cli = "latest"
atuin = "latest"
yazi = "latest"
bottom = "latest"
bat = "latest"
zellij = "0.44.3"               # Pin version due to manual upgrade process
dust = "latest"
hyperfine = "latest"
"aqua:printfn/fend" = "latest"
fzf = "latest"
lazygit = "latest"
delta = "latest"
jq = "latest"
tree-sitter = "latest"
node = "lts"    # Required for nvim copilot.lua
taplo = "latest"
"npm:yaml-language-server" = "latest"
"npm:@fsouza/prettierd" = "latest"

{{- if .dev_env }}

ruff = "latest"
stylua = "latest"
lua = "latest"
bun = "latest"
"aqua:quarylabs/sqruff" = "latest"
lua-language-server = "latest"
biome = "latest"
rust-analyzer = "latest"
"cargo:bacon" = "latest"
tinymist = "latest"
rtk = "latest"
opencode = "latest"

{{- end }}

[settings]
idiomatic_version_file_enable_tools = ["node"]
