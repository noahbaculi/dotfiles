{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "share": "disabled",
  "autoupdate": "notify",
  "snapshot": false,
  "tool_output": {
    "max_lines": 200,
    "max_bytes": 8192
  },
  "mcp": {
    "serena": {
      "type": "local",
      "command": ["serena", "start-mcp-server", "--context=ide", "--project-from-cwd"],
      "enabled": true
    }
  }
}