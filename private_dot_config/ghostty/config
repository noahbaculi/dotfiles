# Font. Ghostty ships JetBrains Mono and Nerd Font icons internally.
font-family = JetBrains Mono
font-size = 14

# Active theme via include. The theme script swings the symlink.
config-file = themes/active.conf

# Zellij compatibility. Both Option keys become Alt so zellij's
# alt-prefix mappings work from either side.
macos-option-as-alt = true
keybind = opt+left=unbind
keybind = opt+right=unbind

# Free up Ctrl+Tab and Ctrl+Shift+Tab. Ghostty binds them to next_tab
# and previous_tab by default, which conflicts with Zellij's use of
# Tab inside its tab and pane modes.
keybind = ctrl+tab=unbind
keybind = ctrl+shift+tab=unbind

# SSH terminfo auto-install. Fixes xterm-ghostty unknown terminal errors
# on remotes the first time you connect.
shell-integration-features = ssh-env,ssh-terminfo

# Fish enables enhanced keyboard reporting when it queries Ghostty. That can
# leak CSI-u Ctrl-C bytes into foreground jobs like ping.
env = fish_features=no-query-term

# Keybindings. Preserve the existing Wezterm bindings.
# Only consume Ctrl-C when there is a selection to copy.
keybind = performable:ctrl+c=copy_to_clipboard
keybind = ctrl+v=paste_from_clipboard
keybind = shift+enter=text:\x1b[200~\n\x1b[201~
