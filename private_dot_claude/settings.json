{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "default"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command' | grep -qiE 'github\\.com' && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Use gh api or other gh subcommands instead of curl for GitHub API requests. This avoids token/rate-limit issues and uses your gh auth credentials.\"}}' || true",
            "if": "Bash(curl:*)",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "syntaxHighlightingDisabled": false,
  "effortLevel": "medium",
  "voice": {
    "enabled": false,
    "mode": "hold"
  },
  "editorMode": "vim",
  "autoCompactEnabled": false,
  "agentPushNotifEnabled": false,
  "voiceEnabled": false
}
