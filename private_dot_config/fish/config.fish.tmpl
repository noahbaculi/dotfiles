# /* vim: set filetype=fish : */

# Set abbreviations
abbr n 'nvim'
abbr gg 'lazygit'

# Functions

## File browse with yazi. Press y to start browsing, press q to quit and change the CWD, press Q to quit without changing the CWD.
function y
	set tmp (mktemp -t "yazi-cwd.XXXXXX")
	yazi $argv --cwd-file="$tmp"
	if set cwd (command cat -- "$tmp"); and [ -n "$cwd" ]; and [ "$cwd" != "$PWD" ]
		builtin cd -- "$cwd"
	end
	rm -f -- "$tmp"
end

# Source
mise activate fish | source
zoxide init fish | source
starship init fish | source
atuin init fish | source

# `-aP` appends to PATH directly (not the universal fish_user_paths) so mise's
# shims, prepended above, stay first in PATH per mise doctor's recommendation.
fish_add_path -aP ~/.config/theme-switcher

set -gx EDITOR nvim

{{- if .dev_env }}

source "$HOME/.cargo/env.fish"

{{- end }}

